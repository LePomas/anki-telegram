# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (the bot only answers this chat).
# Get it from @userinfobot.
TELEGRAM_CHAT_ID=

# AnkiWeb account (used for headless sync)
ANKIWEB_USERNAME=
ANKIWEB_PASSWORD=

# Which AI backend drafts cards: "claude" (default), "gemini", "openrouter", "ollama", or "agy".
#AI_PROVIDER=claude

# --- claude: Claude Code CLI (`claude -p`), authenticated by your Claude
# subscription. Either log in once on this machine (`claude` -> /login) or
# generate a long-lived token with `claude setup-token` and put it here:
#CLAUDE_CODE_OAUTH_TOKEN=
# Optional: model alias or full name passed to `claude --model` (default haiku)
#CLAUDE_MODEL=haiku
# Optional: path to the claude binary if it's not on PATH (systemd often isn't)
#CLAUDE_BIN=claude

# --- gemini: Google AI Studio, free tier. Get a key at https://aistudio.google.com/apikey
# Note: gemini-2.5-pro is often 0-quota on the free tier. Prefer the rolling
# "-latest" aliases over pinned versions (e.g. "gemini-2.5-flash") — pinned
# versions eventually 404 with "no longer available to new users".
#GEMINI_API_KEY=
#GEMINI_MODEL=gemini-flash-latest
# Used automatically on a 429 from GEMINI_MODEL (higher free-tier RPM/RPD).
#GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest

# --- openrouter: https://openrouter.ai/keys — many models have a free ":free" tier.
# nvidia/nemotron-3-ultra is the largest free model as of this writing; check
# https://openrouter.ai/models?max_price=0 for what's current.
#OPENROUTER_API_KEY=
#OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# --- agy: Google Antigravity CLI (`agy -p`), authenticated by your Google AI
# Pro/Ultra login — no API key needed. Install: https://antigravity.google
#AGY_MODEL=Gemini 3.5 Flash (Medium)
# Optional: path to the agy binary if it's not on PATH (systemd often isn't)
#AGY_BIN=agy

# --- ollama: local, no key needed, needs `ollama pull <model>` first.
# For Ollama Cloud (ollama.com) instead, set OLLAMA_HOST=https://ollama.com
# and OLLAMA_API_KEY — check `curl -H "Authorization: Bearer $KEY"
# https://ollama.com/api/tags` for which cloud models are free on your account.
#OLLAMA_HOST=http://localhost:11434
#OLLAMA_MODEL=llama3.1
#OLLAMA_API_KEY=

# Optional: where the local collection + state live (default ./data)
#DATA_DIR=data

# Optional: restrict the "already exists?" search to this deck (and its
# subdecks). Default: search the whole collection.
#ANKI_READ_DECK=Languages::Deutsch
# Optional: default target deck for new cards (still changeable via /deck).
#ANKI_WRITE_DECK=Languages::Deutsch::Kontext B1+

# Optional: language you send words in, and language cards get translated
# into. Any gTTS-supported code works (see /settings in the bot for the
# full picker) — defaults match this project's original German->Spanish setup.
#LANG_SOURCE=de
#LANG_TARGET=es
